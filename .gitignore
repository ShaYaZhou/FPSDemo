# Unreal Engine 本地生成目录
DerivedDataCache/
Intermediate/
Saved/

# 提交预编译编辑器二进制，方便非程序成员直接打开工程。
# 注意：这些二进制只适用于对应 Unreal Engine 版本和平台。
/Binaries/Win64/*
!/Binaries/Win64/UnrealEditor-FPSDemo.dll
!/Binaries/Win64/UnrealEditor.modules
/Plugins/*/Binaries/**
!/Plugins/McpAutomationBridge/Binaries/
!/Plugins/McpAutomationBridge/Binaries/**
/Plugins/*/Intermediate/

# IDE 和工程文件缓存
.vs/
.vscode/
.idea/
*.sln
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb
*.opensdf
*.sdf

# 编译、日志和临时文件
*.log
*.tmp
*.temp

# 本地资源来源说明和网页快捷方式，不作为工程资产提交
资源安装教程.txt
*.url
